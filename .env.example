# ── Configuración de entorno — El mercadito de Julia ────────────────────────
# Copia este archivo como ".env" y completa con tus datos reales.
# NUNCA subas el archivo .env real a GitHub (ya está en .gitignore).

# Entorno: "local" o "production"
APP_ENV=production
# Mostrar errores detallados en pantalla (1 solo en local; 0 en producción)
APP_DEBUG=0

# Prefijo de las rutas:
#   - En XAMPP local (carpeta htdocs/tienda_verduras):  /tienda_verduras
#   - En la nube, si la app vive en la raíz del dominio: deja esto VACÍO
BASE_URL=

# ── Base de datos (te los da tu proveedor de hosting) ───────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=el_mercadito
DB_USER=usuario_db
DB_PASS=contraseña_segura
